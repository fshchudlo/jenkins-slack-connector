{
    "compilerOptions": {
        "target": "es2022",
        "module": "preserve",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "moduleResolution": "bundler",
        "noEmit": true,
        "types": ["node", "jest"]
    },
    "include": ["./**/*.ts"],
    "exclude": ["./node_modules"]
}
