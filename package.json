{
  "name": "jenkins-slack-connector",
  "version": "1.0.0",
  "description": "App to run Jenkins pipelines with Slack commands.",
  "main": "src/app.ts",
  "scripts": {
    "start": "tsx src/app.ts",
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ./src --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:update-snapshots": "jest --updateSnapshot"
  },
  "keywords": [
    "jenkins",
    "slack"
  ],
  "author": "Fedor Shchudlo",
  "license": "Apache 2.0",
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "tsx": "^4.22.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
